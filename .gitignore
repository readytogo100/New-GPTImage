# ============================================================================
#  New-GPTImage.ps1 - .gitignore
#  Excludes secrets, runtime-generated files and OS/editor artifacts.
# ============================================================================

# ----------------------------------------------------------------------------
#  CRITICAL: configuration with the real API key (NEVER commit)
# ----------------------------------------------------------------------------
# The New-GPTImage.conf file contains the models' API keys (even if
# encrypted in DPAPI they remain secrets). Commit New-GPTImage.conf.example
# instead as a template, with sensitive values replaced by placeholders.
New-GPTImage.conf

# ----------------------------------------------------------------------------
#  Files generated at runtime by the script
# ----------------------------------------------------------------------------
# Application log (may contain prompts if the privacy log is enabled)
New-GPTImage.log
*.log

# Time telemetry (kNN estimate)
New-GPTImage.stat
*.stat

# Daily cost aggregate
New-GPTImage.cost
*.cost

# Price discovery (generated when a model is not found on the API)
New-GPTImage.pricing-discovery.json

# Language pack cache (if generated)
New-GPTImage.lang.cache

# Standard file / personal prompt template (often contains your own content).
# The template New-GPTImage.md.example IS published; your real New-GPTImage.md is not:
New-GPTImage.md

# Batch file: the template New-GPTImage.batch.example IS published; your real one is not:
New-GPTImage.batch

# Legacy/scratch time-telemetry export (contains your own usage data):
New-GPTImage.jsonl

# ----------------------------------------------------------------------------
#  Output: gallery, analytics, generated images
# ----------------------------------------------------------------------------
gallery.html
gallery-data.js
gallery_ratings.json
analytics.txt
analytics-*.txt

# Generated images and their metadata/sidecar.
# NB: leading slash = root only, so docs/images/ (the README screenshots) is NOT excluded.
/output/
/images/
/generated/
img_*.png
img_*.jpg
img_*.jpeg
img_*.webp
img_*.json
img_*.txt

# Storyboard (numbered sequences)
story_*.png
story_*.jpg
story_*.jpeg
story_*.webp
story_*.json

# ----------------------------------------------------------------------------
#  Self-test: temporary files and folders generated by the suite
# ----------------------------------------------------------------------------
Test-GPTImage.log
Test-GPTImage-output/
Test-GPTImage-temp-*/
Test-GPTImage-temp-conf-*/

# ----------------------------------------------------------------------------
#  Local backups and exports
# ----------------------------------------------------------------------------
New-GPTImage.conf.bak
New-GPTImage.conf.*.bak
*.tmp
*.bak
*.orig
bench-*.csv

# ----------------------------------------------------------------------------
#  Operating system
# ----------------------------------------------------------------------------
# Windows
Thumbs.db
desktop.ini
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ----------------------------------------------------------------------------
#  IDE / Editor
# ----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# Visual Studio
.vs/
*.user
*.suo

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
.*.swp

# ----------------------------------------------------------------------------
#  Local working notes and archives
# ----------------------------------------------------------------------------
TODO.local.md
NOTES.local.md
scratch/
*.zip
*.tar.gz
*.7z